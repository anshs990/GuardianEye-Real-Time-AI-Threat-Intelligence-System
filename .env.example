# GuardianEye — Environment Variables
# Copy this file to .env and fill in your keys
# Vision Agents auto-reads this file — no need to pass keys manually

# ── Stream (required — get free keys at getstream.io) ────────────────────────
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here

# ── Anthropic / Claude (required) ────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Moondream (required — get free key at moondream.ai) ──────────────────────
MOONDREAM_API_KEY=your_moondream_api_key_here

# ── Deepgram STT (required — free tier at deepgram.com) ──────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── ElevenLabs TTS (required for voice alerts — free tier at elevenlabs.io) ──
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
